<?xml version="1.0" encoding="utf-8"?>
<!-- SCANDINAVIAN ELITE Quick Link — floating card with accent letter -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingTop="4dp"
    android:paddingBottom="4dp"
    android:layout_columnWeight="1">

    <!-- Floating card: 56x56dp, white bg, 16dp radius, 2dp elevation -->
    <FrameLayout
        android:id="@+id/quick_link_card"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/card_bg"
        android:elevation="2dp"
        android:layout_marginBottom="6dp">

        <!-- Single large letter in accent color -->
        <TextView
            android:id="@+id/quick_link_letter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#2D5F6E"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:elevation="1dp" />
    </FrameLayout>

    <!-- Name below card -->
    <TextView
        android:id="@+id/quick_link_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:textColor="#8A8A8A"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />
</LinearLayout>
